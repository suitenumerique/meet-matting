# Venv
.venv/

# Datasets et Vidéos (Trop lourds pour Git)
benchmark/dataset/
benchmark/videos_masques/
benchmark/videos/
benchmark/temp_results
# Résultats du Benchmark
benchmark/output/
benchmark/results/
*.mp4
*.png
*.csv

# Poids des modèles
benchmark/weights/*.onnx
benchmark/weights/*.tflite
benchmark/weights/*.pb
!benchmark/weights/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.env
.venv
env/
venv/
.pytest_cache/

# macOS
.DS_Store
