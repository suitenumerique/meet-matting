# ──────────────────────────────────────────────
#  Git Ignore - Video Matting Benchmark
# ──────────────────────────────────────────────

# Venv
.venv/

# Datasets et Vidéos (Trop lourds pour Git)
benchmark/dataset/
benchmark/videos/

# Résultats du Benchmark
benchmark/output/
benchmark/results/
*.mp4
*.png
*.csv

# Pipeline data et poids
pipeline/data/videos/
pipeline/data/output/
pipeline/weights/
!pipeline/data/videos/.gitkeep
!pipeline/weights/.gitkeep

# Poids des modèles
benchmark/weights/*.onnx
benchmark/weights/*.tflite
benchmark/weights/*.pb
!benchmark/weights/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.env
.venv
env/
venv/
.pytest_cache/

# Tooling caches
.mypy_cache/
.ruff_cache/
.dmypy.json
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
build/
dist/
*.egg-info/

# IDE
.vscode/
.idea/
*.swp

# macOS
.DS_Store

# Claude Code
CLAUDE.md
.claude/
claude_pipeline_architecture.md